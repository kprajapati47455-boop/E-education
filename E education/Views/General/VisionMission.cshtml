
@{
    ViewBag.Title = "VisionMission";
    Layout = "~/Views/Shared/common_generallayout.cshtml";
}
<style>
    p {
        display: flex;
        justify-content: center;
        align-items: center;
    }

    img {
        border-radius: 20px;
    }
</style>
 
<div class="row">
    <h1 class="text-info mt-4" style=" text-align: center; font-family: 'Times New Roman', Times, serif" class="mt-4 p-3">Vision & Mission</h1>
    <hr />
    <div data-aos="fade-up" class=" row mt-5">
        <div class="col-sm-6">
            <img src="~/content/images/ourvision.jpg" width="100%" style="height:300px;" />
        </div>
        <div class=" col-sm-6">
            <h2 class="text-primary" style="text-align:center; font-family:'Times New Roman', Times, serif">Our vision</h2>
            <p class="p-4">Our vision is to revolutionize learning by making quality education accessible, affordable, and engaging for every learner—anytime, anywhere. We aim to build a global platform that empowers students through technology, innovation, and personalized learning experiences.</p>
        </div>
    </div>
    <div data-aos="fade-up" class="row mt-5">
        <div class="col-sm-6">
            <h2 class="text-primary" style="text-align:center;font-family:'Times New Roman', Times, serif">Our Mission</h2>
            <p class="p-4">Our mission is to transform the way people learn by offering high-quality, affordable, and interactive digital education. We strive to break down barriers of location, cost, and access by creating a platform where anyone—regardless of background—can learn, grow, and succeed. Through continuous innovation and learner-focused content, we aim to make education not just a service, but a right for everyone.</p>
        </div>
        <div class="col-sm-6">
            <img src="~/content/images/mission1.jpeg" width="100%" style="height:300px;" />
        </div>
    </div>
    <div data-aos="fade-up" class="row mt-5">
        <div class="col-sm-6">
            <img src="~/content/images/promise.jpg" width="100%" style="height:400px;" />
        </div>
        <div class="col-sm-6">
            <h2 class="text-center text-primary" style="font-family:'Times New Roman', Times, serif">Our Promise</h2>
            <p>
                At E-Eduction, we are committed to making high-quality education accessible,
                inclusive, and affordable for learners everywhere.

                We believe that learning should not be limited by geography, background, or financial constraints. Our mission is to empower individuals by providing them with the tools, content, and support they need to succeed in a rapidly evolving world.

                We promise to:
                <ul>
                    <li> Deliver engaging, up-to-date, and interactive learning experiences.</li>

                    <li> Ensure equal access to education regardless of socio-economic background.</li>

                    <li> Leverage cutting-edge technology to personalize and enhance the learning journey.</li>

                    <li>Protect the privacy and data of all our learners with the highest standards of security.</li>

                    <li>Continuously improve our offerings based on feedback and innovation.</li>

                    Education is a fundamental right — not a privilege — and we are dedicated to making that right a reality for all.
                </ul>
            </p>
        </div>
    </div>
</div>

