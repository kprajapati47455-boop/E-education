
@{
    Layout = null;
}
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Common_Studentlayout</title>
    <link href="~/content/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <script src="~/content/js/jquery/jquery-3.7.1.min.js"></script>
    <script src="~/content/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row bg-primary">
            <div class="col-sm-3">
                <img class=" bg-primary" src="~/content/images/cap1.png" height="80px" style="border-radius:50%;margin-left:10px" />
            </div>
            <div class="col-sm-6">
                <h1 class="text-center text-light p-2" style=" font-family:'Times New Roman', Times, serif">Welcome to Student panel..</h1>
            </div>
            <div class="col-sm-3">
                <img src= "/content/pic/@ViewBag.Userpic" class="rounded-circle p-2" height="50px" />
                <span class="fs-4 fw-bold">@ViewBag.Username</span>
            </div>

        </div>
        <div class="row">
            <div class="col-sm-2 m-0 p-0 ">
                <nav class="navbar navbar-expand-lg navbar-light bg-primary  ">
                    <div class="container-fluid">
                       
                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="navbarNavDropdown">
                            <ul class="navbar-nav flex-column p-0 ">
                                <li class="nav-item">
                                    <a class="nav-link active text-light " style="font-size:14px;"  aria-current="page" href="/Student/HDashboard"><i class="bi bi-house-door-fill"></i> Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:14px;" href="/Student/ViewAssignment"><i class="bi bi-file-earmark-easel"></i> View Assignment</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light"  style="font-size:14px;" href="/Student/ViewStudyMaterial"><i class="bi bi-box-arrow-in-down"></i> View Study Material</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:14px;"  href="/Student/UploadAssignment"><i class="bi bi-file-earmark-arrow-up-fill"></i> Upload Assignment</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light"  style="font-size:14px;" href="/Student/Feedback"><i class="bi bi-reply-all-fill"></i> Feedback</a>
                                </li>
                                <li class=" nav-item">
                                <a class="nav-link text-light"  style="font-size:14px;" href="/Student/MyProfile"><i class="bi bi-person-circle"></i> My Profile</a>
                                </li>
                                <li class="nav-item">
                                <a class="nav-link text-light"  style="font-size:14px;" href="/Student/ChangePassword"><i class="bi bi-key-fill"></i> Change Password</a>
                                </li>
                                <li class=" nav-item">
                                <a class="nav-link text-light" style="font-size:14px;"  href="/Student/LogOut"><i class="bi bi-box-arrow-right"></i> Logout</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </nav>
                
            </div>
            <div class="col-sm-10">
           
                @RenderBody()
            </div>
        </div>
       
    </div>
</body>
</html>
