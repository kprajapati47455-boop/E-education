
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Common_Studentlayout</title>
    <link href="~/content/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <script src="~/content/js/jquery/jquery-3.7.1.min.js"></script>
    <script src="~/content/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row bg-primary">
            
            <div class="col-sm-2 pt-2">
                <img class=" bg-primary" src="~/content/images/cap1.png" height="80px" style="border-radius:50%;margin-left:10px"/>
            </div>
            <div class="col-sm-8">
                <h1 class="text-center text-light p-2" style="font-family:'Times New Roman', Times, serif">Welcome to Admin panel..</h1>
            </div>
            <div class="col-sm-2 pt-2">
                <img src="~/content/images/myimage1.jpg" style=" border-radius:50%" height="50px" width="60px"/>
                <span class="fs-4 fw-bold">Krishna</span>
            </div>

        </div>
        <!--row for navbar-->
        <div class="row text-light">
            <div class="col-sm-2 m-0 p-0">
                <nav class="navbar navbar-expand-lg navbar-light bg-primary" >
                    <div class="container-fluid">

                        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <div class="collapse navbar-collapse" id="navbarNavDropdown">
                            <ul class="navbar-nav flex-column text-light m-0 p-0">
                                <li class="nav-item">
                                    <a class="nav-link active text-light" aria-current="page" href="/Admin/Dashboard"><i class="bi bi-house-door-fill"></i> <b>Dashboard</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/StudentManagement"><i class="bi bi-kanban-fill"></i> <b>Student Management</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/UploadAssignment"><i class="bi bi-cloud-arrow-up-fill"></i> <b>Upload Assignment</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/StudyMaterials"><i class="bi bi-book-fill"></i> <b>Study Material</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/NotificationManagement"><i class="bi bi-bell-fill"></i> <b>Notification Management</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/AddNotification"><i class="bi bi-bell-fill"></i> <b>Add Notification</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/EnquiryManagement"> <b>Enquery Management</b></a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/SendEmail"><i class="bi bi-envelope-arrow-up-fill"></i> <b>Send Email</b></a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/AssignmentManagement"><i class="bi bi-journals"></i> <b>Assignment Management</b></a>
                                </li>
                                <li class=" nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/FeedbackManagement"><i class="bi bi-reply-fill"></i> <b>Feedback Management</b></a>
                                </li>
                                <li class=" nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/ChangePassword"><i class="bi bi-key-fill"></i><b>Change Password</b></a>
                                </li>
                                <li class=" nav-item">
                                    <a class="nav-link text-light" style="font-size:12px;" href="/Admin/LogOut"><i class="bi bi-box-arrow-right"></i><b>LogOut</b></a>
                                </li>
                            </ul>
                                
                            
                        </div>
                    </div>
                </nav>

            </div>
            <div class="col-sm-10">
             
                @RenderBody()
            </div>
        </div>
        
    </div>
</body>
</html>

