
@{
    ViewBag.Title = "ChangePassword";
    Layout = "~/Views/Shared/Common_Studentlayout.cshtml";
}



 
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notification Form</title>
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <script src="js/bootstrap.min.js"></script>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
          integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <!-- AOS CSS -->
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

    <style>
        .login-card:hover {
            transform: scale(1.02);
            transition: all 0.3s ease-in-out;
        }

        A
        textarea:focus {
            border-color: #0d6efd;
        }

        button:hover {
            background-color: #004bbd !important;
        }

        body {
            overflow-x: hidden;
        }
    </style>
</head>

<body style="background: linear-gradient(to right, aqua, whitesmoke); min-height: 100vh;">
    <!-- Hero Section with AOS -->
    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1000"
         style="margin-top:40px; text-align: center; padding: 80px 20px; color: #fff; background: linear-gradient(135deg, #1a73e8, #0f4c75); border-radius: 10px; margin-bottom: 40px;">
        <h1 style="font-size: 40px; font-weight: bold; font-family:'Times New Roman', Times, serif;">Welcome to Change Password Module</h1>
        <h2><span id="typed"></span></h2>
        <p style="font-size: 18px; margin-top: 10px; font-family:'Times New Roman', Times, serif;">This module manages password change functionality!</p>
    </div>

    <div class="container-fluid" style="padding-bottom:80px;">
        <div class="row justify-content-center login-card max-auto">
            <div class="col-12 col-sm-8 col-lg-6">
                <div class="mt-5 p-4 border border-dark rounded bg-secondary-subtle shadow"
                     style="background-color: rgb(90, 201, 228); border-radius: 20px;" data-aos="fade-up" data-aos-duration="1000">
                    <form action="/Student/ChangePassword" method="post">
                        <div class="text-center sm-4 d-flex justify-content-center align-items-center gap-3" style="margin-bottom: 20px;">
                            <i class="fa-solid fa-key" style="font-size: 40px;"></i>
                            <h2 class="m-0">Confirm Password</h2>
                            <p class="text-center bg-success">@ViewBag.Message</p>
                        </div>

                        <div class="mb-3">
                            <label for="pass" class="form-label">Enter Current Password</label>
                            <input type="password" class="form-control" id="pass" name="CPass" required>
                            <br>
                            <label for="newpass" class="form-label">New Password</label>
                            <input class="form-control" type="password" id="newpass" name="NewPass">
                            <br>
                            <label for="cpass" class="form-label">Confirm New Password</label>
                            <input class="form-control" type="password" id="cpass" name="ConfPass">
                            <br>
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary">Change Password</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- AOS JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>AOS.init();</script>
</body>
</html>