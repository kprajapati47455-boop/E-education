
@{
    ViewBag.Title = "EnquiryManagement";
    Layout = "~/Views/Shared/commn_admin_layout.cshtml";
}
 @using E_education.Models
@model List<Tbl_Enquiry>

<!-- AOS CSS -->
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

<body style="background: linear-gradient(120deg, #6a11cb 0%, #2575fc 100%); min-height: 100vh;">

    <!-- Hero Section -->
    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1000"
         style="margin-top:40px; text-align: center; padding: 80px 20px; color: #fff; background: linear-gradient(135deg, #1a73e8, #0f4c75); border-radius: 10px; margin-bottom: 40px;">
        <h1 style="font-size: 40px; font-weight: bold; font-family: cursive;">Hi, I’m <strong>Krishna</strong></h1>
        <h2><span id="typed"></span></h2>
        <p style="font-size: 18px; margin-top: 10px; font-family: cursive;">.NET Full Stack Developer | Fast Learner |</p>
    </div>

    <!-- Enquiry Table Section -->
    <div class="row" data-aos="fade-up" data-aos-duration="1000">
        <div class="col-sm-1"></div>
        <div class="col-sm-10">
            <h3 class="text-light bg-warning text-center p-4">Enquiry List</h3>
            <p class="text-danger text-center">@TempData["Message"]</p>
            <table class="table table border-2">
                <tr>
                    <th>Sno.</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>MobileNo</th>
                    <th>Message</th>
                    <th>EnquiryDate</th>
                    <th>Delete</th>
                </tr>
                @{
                    int sno = 1;
                    foreach (Tbl_Enquiry em in Model)
                    {
                        <tr data-aos="zoom-in" data-aos-duration="800">
                            <td>@sno</td>
                            <td>@em.Name</td>
                            <td>@em.Email</td>
                            <td>@em.Mobile_No</td>
                            <td>@em.Message</td>
                            <td>@em.Enquiry</td>
                            <td><a href="/Admin/DeleteEnquiry?id=@em.Enquiry_id"><i class="fa-solid fa-trash text-danger"></i></a></td>
                        </tr>
                        sno++;
                    }
                }
            </table>
        </div>
        <div class="col-sm-1"></div>
    </div>

    <!-- AOS JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>AOS.init();</script>
</body>


