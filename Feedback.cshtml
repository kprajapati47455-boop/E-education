
@{
    ViewBag.Title = "Feedback";
    Layout = "~/Views/Shared/Common_Studentlayout.cshtml";
}

<!-- AOS CSS -->
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

<!--form start-->
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Document</title>
<link rel="stylesheet" href="css/bootstrap.min.css" />
<script src="js/bootstrap.min.js"></script>

<style>
    body {
        overflow-x: hidden;
    }

    .bg-cover {
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .form-wrapper {
        background-color: rgba(150, 183, 239, 0.9);
        border-radius: 20px;
        padding: 40px;
        box-shadow: rgb(232, 87, 9) 0px 20px 30px -10px;
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
    }

        .form-wrapper:hover {
            transform: scale(1.02);
            box-shadow: white 0px 30px 40px -10px;
        }

    .btn-primary:hover {
        background-color: #004bbd;
        transform: scale(1.05);
        transition: all 0.3s ease-in-out;
    }

    .form-wrapper {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease;
        border: 1px solid rgba(255, 255, 255, 0.18);
    }

    body {
/*        background-image: url('image/formbackground.webp');*/
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<body style="background:  linear-gradient(to right, aqua, whitesmoke); min-height: 100vh;">

    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1300"
         style="margin-top:40px; text-align: center; padding: 80px 20px; color: #fff; background: linear-gradient(135deg, #1a73e8, #0f4c75); border-radius: 10px; margin-bottom: 40px;">
        <h1 style="font-size: 40px; font-weight: bold; font-family:'Times New Roman', Times, serif;"><strong>Feedback Module</strong></h1>
        <h2><span id="typed"></span></h2>
        <p style="font-size: 18px; margin-top: 10px; font-family:'Times New Roman', Times, serif;">This module manage feedback work!</p>
    </div>

    <div class="container-fluid" data-aos="fade-up" data-aos-duration="1300">
        <div class="row justify-content-center align-items-center" style="min-height: 100vh;">
            <div class="col-12 col-md-8 col-lg-6" style="border: 1px solid rgb(165, 190, 204);border-radius: 20px; color: rgb(5, 5, 5); padding: 40px; background-color: rgb(150, 183, 239); box-shadow: black 0px 20px 30px -10px;">
                <div class="form-wrapper">
                    <p style="text-align:center;color:green;">@ViewBag.Message</p>
                    <form action="/Student/Feedback" method="post">
                        <h1 class="mb-6 text-center" style="font-family: Georgia, 'Times New Roman', Times, serif;">
                            Please send your valuable feedback
                        </h1>
                        <label for="title" class="form-label">Title to feedback</label>
                        <input type="text" class="form-control" id="Topic" name="" required>
                        <br>
                        <label for="type" class="form-label">Type your feedback....</label>
                        <textarea name="Message" id="type" class="form-control" required></textarea>
                        <br>
                        <div class="text-center">
                            <button class="for btn btn-primary btn-lg" type="submit">Add Feedback</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- AOS JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init();
    </script>
</body>



