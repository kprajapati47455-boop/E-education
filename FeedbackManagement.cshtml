
@{
    ViewBag.Title = "FeedbackManagement";
    Layout = "~/Views/Shared/commn_admin_layout.cshtml";
}

 
@using E_education.Models
@model List<Feedback_Tbl>

<!-- AOS CSS -->
<link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet" />

<body style="background: linear-gradient(120deg, #6a11cb 0%, #2575fc 100%); min-height: 100vh;">

    <!-- Hero Section -->
    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1000"
         style="margin-top:40px; text-align: center; padding: 80px 20px; color: #fff; background: linear-gradient(135deg, #1a73e8, #0f4c75); border-radius: 10px; margin-bottom: 40px;">
        <h1 style="font-size: 40px; font-weight: bold; font-family:'Times New Roman', Times, serif;"><strong>Feedback Management Module</strong></h1>
        <h2><span id="typed"></span></h2>
        <p style="font-size: 18px; margin-top: 10px; font-family:'Times New Roman', Times, serif;">This module handle your all feedback modules!</p>
    </div>

    <!-- Feedback Table Section -->
    <div class="row" data-aos="fade-up" data-aos-duration="1000">
        <div class="col-sm-1"></div>
        <div class="col-sm-10">
            <h3 class="text-primary text-center p-3 bg-warning">Feedback Management</h3><hr />
            <table class="table table-stiped table-hover">
                <tr>
                    <th>Sno.</th>
                    <th>Name</th>
                    <th>Pic</th>
                    <th>EmailId</th>
                    <th>College</th>
                    <th>Feedback Topic</th>
                    <th>Feedback Message</th>
                    <th>Feedback Date</th>
                </tr>
                @{
                    int sno = 1;
                    foreach (Feedback_Tbl rm in Model)
                    {
                        <tr data-aos="zoom-in" data-aos-duration="800">
                            <td>@sno</td>
                            <td>@rm.Registration_Master.Name</td>
                            <td>
                                <img src="/content/pic/@rm.Registration_Master.pic_Upload" style="height:50px;width:50px;border-radius:50px;" />
                            </td>
                            <td>@rm.Registration_Master.Email_id</td>
                            <td>@rm.Registration_Master.College</td>
                            <td>@rm.Topic</td>
                            <td>@rm.Message</td>
                            <td>@rm.Feedback_DT</td>
                        </tr>
                        sno++;
                    }
                }
            </table>
        </div>
        <div class="col-sm-1"></div>
    </div>

    <!-- AOS JS -->
    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>AOS.init();</script>
</body>

