
@{
    ViewBag.Title = "UploadAssignment";
    Layout = "~/Views/Shared/commn_admin_layout.cshtml";
}

 

<body style="background-color: mediumpurple;">
    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1000">
    <div class="hero-section" data-aos="zoom-in" data-aos-duration="1000"
         style="margin-top:40px; text-align: center; padding: 80px 20px; color: #fff; background: linear-gradient(135deg, #1a73e8, #0f4c75); border-radius: 10px; margin-bottom: 40px;">

        <h1 style="font-size: 40px; font-weight: bold; font-family:'Times New Roman', Times, serif;"><strong>Uploadassignment Module</strong></h1>
        <h2><span id="typed"></span></h2>
        <p style="font-size: 18px; margin-top: 10px; font-family:'Times New Roman', Times, serif;">This module manage all uplode assignment work!</p>
    </div>
    <div class="row my-3">
        <div class="col-sm-3"></div>
        <div class="col-sm-6">
            <h3 class="bg-warning text-light text-center p-3">Upload Assignment</h3>
            <p style="text-align:center;color:green;">@ViewBag.Message</p>
            <form action="/Admin/UploadAssignment" method="post" enctype="multipart/form-data">
                <input type="text" placeholder="Enter title of assignment" name="Title" class="form-control" />
                <br />
                <textarea class="form-control" placeholder="Enter description of assignment" name="Description" style="resize:none;"></textarea>
                <br />
                <input type="file" name="Filename" class="form-control" />
                <br />
                <input type="submit" value="UploadAssignment" class="btn btn-success" />
            </form>
        </div>
        <div class="col-sm-3"></div>

    </div>
    </div>
</body>

